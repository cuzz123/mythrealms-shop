{
  "buildCommand": "npx prisma generate && next build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/automation/send-daily-report",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/automation/low-stock-alert",
      "schedule": "0 1 * * *"
    }
  ]
}