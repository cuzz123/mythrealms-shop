{
  "name": "MythRealms — Daily Operations Report Email",
  "nodes": [
    {
      "parameters": { "rule": { "interval": [{}] }, "triggerTimes": { "hour": 8, "minute": 0 } },
      "name": "Daily at 8am",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [250, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://mythrealms-shop.vercel.app/api/automation/daily-report",
        "sendBody": true,
        "bodyParameters": { "parameters": [] },
        "options": {}
      },
      "name": "Fetch Daily Metrics",
      "type": "n8n-nodes-base.httpRequest",
      "position": [450, 300]
    },
    {
      "parameters": {
        "fromEmail": "noreply@mythrealms-shop.vercel.app",
        "toEmail": "zheng111321@gmail.com",
        "subject": "MythRealms Daily Report — ={{ $json.date }}",
        "emailType": "text",
        "message": "📊 MythRealms Daily Report\n━━━━━━━━━━━━━━━━\n📅 {{ $json.date }}\n\n📦 Orders Today: {{ $json.metrics.ordersToday }}\n📬 Pending Shipment: {{ $json.metrics.ordersPendingShipment }}\n💰 Total Revenue: ${{ $json.metrics.totalRevenue }}\n⚠️ Low Stock Products: {{ $json.metrics.lowStockProducts }}\n\n🔗 https://mythrealms-shop.vercel.app/admin/orders"
      },
      "name": "Email Report",
      "type": "n8n-nodes-base.emailSend",
      "position": [650, 300]
    }
  ],
  "connections": {
    "Daily at 8am": { "main": [[ { "node": "Fetch Daily Metrics", "type": "main", "index": 0 } ]] },
    "Fetch Daily Metrics": { "main": [[ { "node": "Email Report", "type": "main", "index": 0 } ]] }
  }
}
