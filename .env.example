# Environment Variables
# Copy this file to .env and fill in the values

# Database (Vercel Postgres or Neon)
DATABASE_URL="postgresql://user:password@localhost:5432/mythrealms"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# NextAuth (Auth.js)
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-generate-with-openssl-rand-base64-32"
# MUST be the canonical public URL of your deployment — NextAuth uses this
# to construct callback URLs. In production, set this to your Vercel domain:
#   AUTH_URL="https://mythrealms.vercel.app"
# If you use a custom domain, use that instead:
#   AUTH_URL="https://mythrealms.shop"
AUTH_URL="http://localhost:3000"

# === LemonSqueezy (Payment Provider) ===
# Get these from your LemonSqueezy dashboard: https://app.lemonsqueezy.com/settings
LEMONSQUEEZY_API_KEY=""
LEMONSQUEEZY_STORE_ID=""
LEMONSQUEEZY_WEBHOOK_SECRET=""

# Option A: Create a "Checkout" variant in LemonSqueezy for API-based checkout
# This single variant acts as the payment gateway for all orders
# Set its price to $1 and we'll pass the actual total as custom data
LEMONSQUEEZY_VARIANT_ID=""

# Option B (fallback): Direct buy link
# If you prefer a simpler setup, create a product in LemonSqueezy
# and use its direct checkout URL
LEMONSQUEEZY_PRODUCT_UUID=""
LEMONSQUEEZY_STORE_DOMAIN="your-store.lemonsqueezy.com"

# === PayPal (optional) ===
# Get your Client ID from PayPal Developer Dashboard: https://developer.paypal.com/
# Sandbox (test): https://developer.paypal.com/dashboard/applications/sandbox
# Live: https://developer.paypal.com/dashboard/applications/live
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id

# === Email (Resend) ===
# Get your API key from https://resend.com/api-keys
RESEND_API_KEY=""

# === Google OAuth (optional) ===
# Remove Google provider from auth.ts if not used
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# === Analytics (optional) ===
NEXT_PUBLIC_GA_ID=""
NEXT_PUBLIC_META_PIXEL_ID=""

# === Vercel Blob Storage (CDN for product images) ===
# 1. Go to Vercel Dashboard -> Storage -> Blob -> Create Database
# 2. Copy BLOB_READ_WRITE_TOKEN from Settings
# 3. Run the image upload script to populate Blob:
#      npx tsx scripts/upload-images-to-blob.ts
# 4. After upload, the script outputs a base URL. Copy it here.
#    Example format: https://<STORE_ID>.public.blob.vercel-storage.com
# 5. Set NEXT_PUBLIC_MEDIA_BASE to that URL (no trailing slash).
#    # Example: NEXT_PUBLIC_MEDIA_BASE=https://abc123xyz.public.blob.vercel-storage.com
# Once set, all product images will serve from Blob CDN via imageUrl() helper.
# When left empty, images fall back to local /images/ paths.
BLOB_READ_WRITE_TOKEN=
NEXT_PUBLIC_MEDIA_BASE=

# === Upstash Redis (rate limiting) ===
# Get from https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# === PayPal ===
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-secret
PAYPAL_WEBHOOK_ID=your-webhook-id
PAYPAL_API_BASE=https://api-m.paypal.com
